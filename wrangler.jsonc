{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bg",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "bg.skeptrune.com",
      "custom_domain": true
    }
  ]
}

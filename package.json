{
  "name": "backgammon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fetch-engine": "bash scripts/fetch-engine.sh",
    "dev": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build": "tsc -b && tsc -p worker && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "type": "tsc -b --noEmit && tsc -p worker",
    "migrate": "wrangler d1 migrations apply bg --local",
    "migrate:remote": "wrangler d1 migrations apply bg --remote",
    "smoke": "node scripts/engine-smoke.cjs",
    "resume": "node scripts/engine-resume.cjs",
    "deploy": "npm run fetch-engine && npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.27",
    "idb-keyval": "^6.2.2",
    "kysely": "^0.29.2",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.107.0"
  }
}
